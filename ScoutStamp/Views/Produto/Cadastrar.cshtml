@model ScoutStamp.Models.Produto

@{
    ViewData["Title"] = "Cadastrar";
}

<style>
    .container-centralizado {
        display: flex;
        justify-content: center; /* horizontal */
        align-items: center; /* vertical */
        height: 50vh; /* altura total da viewport */    
    }

    .formulario {
        background-color: #4169E1;
        padding: 20px;
        border-radius: 8px;
        color: white;
        width: 450px;
        height: 300px;
        box-sizing: border-box;
        text-align: center;
    }

    /* Centralizar o botão e dar espaçamento */
    .btn-enviar {
        display: block;
        width: 35%;
        height: 50%;
        color: #4169E1;
        margin: 20px auto 0 auto; /* topo 20px, horizontal auto para centralizar */
    }

    /* Centralizar títulos */
    h1, h4 {
        text-align: center;
        font-weight: bold;
        margin: 0 0 10px 0;
    }
</style>

<div class="container-centralizado">
    <div>
        <h1>Cadastrar</h1>
        <h4>Produto</h4>
        <hr />
        <div class="formulario">
            <form asp-action="Cadastrar">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="IdProduto" class="control-label"></label>
                    <input asp-for="IdProduto" class="form-control" />
                    <span asp-validation-for="IdProduto" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Nome" class="control-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Enviar" class="btn btn-light btn-enviar" />
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}